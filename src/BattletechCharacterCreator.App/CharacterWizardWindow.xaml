<Window x:Class="BattletechCharacterCreator.App.CharacterWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="A Time of War Character Wizard"
        Width="1240" Height="760"
        MinWidth="1050" MinHeight="650"
        Background="#F4F3F0"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <FontFamily x:Key="MontserratBlack">/BattletechCharacterCreator.App;component/Assets/Fonts/#Montserrat</FontFamily>
        <Style x:Key="StepLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BDBDB9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MontserratBlack}"/>
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="Foreground" Value="#202020"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="72"/>
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2" Background="#292A28">
            <Grid Margin="24,26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="A TIME OF WAR"
                               FontFamily="{StaticResource MontserratBlack}"
                               FontSize="21"
                               Foreground="White"/>
                    <TextBlock Text="CHARACTER WIZARD"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="13"
                               Foreground="#C7C7C2"
                               Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="2">
                    <TextBlock x:Name="Step0Label" Text="01  Basic Information" Style="{StaticResource StepLabel}"/>
                    <TextBlock x:Name="Step1Label" Text="02  Stage 0 · Affiliation" Style="{StaticResource StepLabel}"/>
                    <TextBlock x:Name="Step2Label" Text="03  Stage 1 · Early Childhood" Style="{StaticResource StepLabel}"/>
                    <TextBlock x:Name="Step3Label" Text="04  Stage 2 · Late Childhood" Style="{StaticResource StepLabel}"/>
                    <TextBlock x:Name="Step4Label" Text="05  Stage 3 · Education" Style="{StaticResource StepLabel}"/>
                    <TextBlock x:Name="Step5Label" Text="06  Stage 4 · Careers" Style="{StaticResource StepLabel}"/>
                    <TextBlock x:Name="Step6Label" Text="07  Review" Style="{StaticResource StepLabel}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="32,26,32,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="TotalsGapRow" Height="0"/>
                <RowDefinition x:Name="TotalsRow" Height="0"/>
            </Grid.RowDefinitions>
            <Grid x:Name="BasicInfoPage">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="BASIC INFORMATION" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="Character name" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="CharacterName" Text="New Character"/>
                    <TextBlock Text="Home planet" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="HomePlanetPicker" IsEditable="True"/>
                    <TextBlock Text="Sex" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="SexPicker"/>
                    <TextBlock Text="Age" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="AgeInput" Text="21"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,51,0,0">
                    <TextBlock Text="Height (cm)" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="HeightInput" Text="175"/>
                    <TextBlock Text="Weight (kg)" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="WeightInput" Text="80"/>
                    <TextBlock Text="Hair color" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="HairColorPicker" IsEditable="True"/>
                    <TextBlock Text="Eye color" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="EyeColorPicker" IsEditable="True"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="Stage0Page" Visibility="Collapsed">
                <Grid Margin="0,0,384,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="100"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Affiliation" Style="{StaticResource FieldLabel}" Margin="0,0,0,2"/>
                            <ComboBox x:Name="AffiliationPicker" DisplayMemberPath="Name"
                                      SelectionChanged="ModuleSelectionChanged"/>
                            <TextBlock Text="Sub-affiliation" Style="{StaticResource FieldLabel}"/>
                            <StackPanel x:Name="SubAffiliationPanel">
                                <ComboBox x:Name="SubAffiliationPicker" DisplayMemberPath="Name"
                                          SelectionChanged="DependentSelectionChanged"/>
                            </StackPanel>
                            <TextBlock Text="Primary language" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="LanguagePicker" SelectionChanged="ChoiceSelectionChanged"/>
                            <StackPanel x:Name="CastePanel" Visibility="Collapsed">
                                <TextBlock Text="Clan caste" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CastePicker" DisplayMemberPath="Name"
                                          SelectionChanged="DependentSelectionChanged"/>
                            </StackPanel>
                        </StackPanel>
                        <GroupBox Grid.Column="2" Header="Order"
                                  VerticalAlignment="Top">
                            <StackPanel Margin="6,2">
                                <CheckBox x:Name="OrderMemberCheck"
                                          Content="ComStar or Word of Blake"
                                          Checked="OrderSelectionChanged"
                                          Unchecked="OrderSelectionChanged"/>
                                <StackPanel Margin="18,3,0,0"
                                            IsEnabled="{Binding IsChecked, ElementName=OrderMemberCheck}">
                                    <RadioButton x:Name="ComStarRadio"
                                                 Content="ComStar"
                                                 GroupName="Order"
                                                 IsChecked="True"
                                                 Checked="OrderSelectionChanged"/>
                                    <RadioButton x:Name="WordOfBlakeRadio"
                                                 Content="Word of Blake"
                                                 GroupName="Order"
                                                 Margin="0,3,0,0"
                                                 Checked="OrderSelectionChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <DataGrid x:Name="Stage0Attributes"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" HeadersVisibility="Column"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Attributes" Binding="{Binding Name}" Width="62"/>
                                    <DataGridTextColumn Header="XP" Binding="{Binding Value}" Width="42"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <DataGrid Grid.Column="2" x:Name="Stage0Traits"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" HeadersVisibility="Column"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Traits" Binding="{Binding Name}" Width="145"/>
                                    <DataGridTextColumn Header="XP" Binding="{Binding Value}" Width="42"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <DataGrid Grid.Column="4" x:Name="Stage0Skills"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" HeadersVisibility="Column"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Skills" Binding="{Binding Name}" Width="145"/>
                                    <DataGridTextColumn Header="XP" Binding="{Binding Value}" Width="42"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>

                    <GroupBox Grid.Row="4" Header="Affiliation Overview">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,4">
                            <TextBlock x:Name="AffiliationDescription"
                                       TextWrapping="Wrap"
                                       Foreground="#454545"/>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </Grid>

            <Grid x:Name="Stage1Page" Visibility="Collapsed">
                <Grid Margin="0,0,474,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="92"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.ColumnSpan="3"
                                   Text="STAGE 1 · EARLY CHILDHOOD"
                                   Style="{StaticResource SectionTitle}"
                                   Margin="0"/>
                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Early childhood"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,0,0,2"/>
                            <ComboBox x:Name="ChildhoodPicker"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="ModuleSelectionChanged"/>
                        </StackPanel>
                        <Border Grid.Row="2"
                                Grid.Column="2"
                                VerticalAlignment="Top"
                                BorderBrush="#A7A7A2"
                                BorderThickness="1"
                                Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="MODULE XP"
                                           FontSize="11"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="ChildhoodModuleCost"
                                           FontFamily="{StaticResource MontserratBlack}"
                                           FontSize="21"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <GroupBox Grid.Row="2" Header="Early Childhood Overview">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,6">
                            <TextBlock x:Name="ChildhoodDescription"
                                       TextWrapping="Wrap"
                                       Foreground="#454545"
                                       LineHeight="20"/>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </Grid>

            <Grid x:Name="Stage2Page" Visibility="Collapsed">
                <Grid Margin="0,0,474,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="92"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.ColumnSpan="3"
                                   Text="STAGE 2 · LATE CHILDHOOD"
                                   Style="{StaticResource SectionTitle}"
                                   Margin="0"/>
                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Late childhood"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,0,0,2"/>
                            <ComboBox x:Name="LateChildhoodPicker"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="ModuleSelectionChanged"/>
                        </StackPanel>
                        <Border Grid.Row="2"
                                Grid.Column="2"
                                VerticalAlignment="Top"
                                BorderBrush="#A7A7A2"
                                BorderThickness="1"
                                Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="MODULE XP"
                                           FontSize="11"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="LateChildhoodModuleCost"
                                           FontFamily="{StaticResource MontserratBlack}"
                                           FontSize="21"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <GroupBox Grid.Row="2" Header="Late Childhood Overview">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,6">
                            <TextBlock x:Name="LateChildhoodDescription"
                                       TextWrapping="Wrap"
                                       Foreground="#454545"
                                       LineHeight="20"/>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </Grid>

            <Grid x:Name="Stage3Page" Visibility="Collapsed">
                <Grid Margin="0,0,474,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="102"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.ColumnSpan="3"
                                   Text="STAGE 3 · EDUCATION"
                                   Style="{StaticResource SectionTitle}"
                                   Margin="0"/>
                        <StackPanel Grid.Row="2">
                            <CheckBox x:Name="EducationCheck"
                                      Content="Attend formal education"
                                      Margin="0,0,0,7"
                                      FontWeight="SemiBold"
                                      Checked="EducationSelectionChanged"
                                      Unchecked="EducationSelectionChanged"/>
                            <Grid x:Name="EducationFieldsPanel"
                                  IsEnabled="{Binding IsChecked, ElementName=EducationCheck}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="School"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,0,0,2"/>
                                    <ComboBox x:Name="SchoolPicker"
                                              DisplayMemberPath="Name"
                                              SelectionChanged="SchoolSelectionChanged"/>
                                </StackPanel>
                                <StackPanel x:Name="BasicFieldPanel" Grid.Column="2">
                                    <TextBlock Text="Basic field"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,0,0,2"/>
                                    <ComboBox x:Name="BasicFieldPicker" DisplayMemberPath="Name"
                                              SelectionChanged="DependentSelectionChanged"/>
                                </StackPanel>
                                <StackPanel x:Name="AdvancedFieldPanel" Grid.Row="2">
                                    <TextBlock Text="Advanced field (optional)"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,0,0,2"/>
                                    <ComboBox x:Name="AdvancedFieldPicker" DisplayMemberPath="Name"
                                              SelectionChanged="AdvancedFieldSelectionChanged"/>
                                </StackPanel>
                                <StackPanel x:Name="SpecialistFieldPanel"
                                            Grid.Row="2"
                                            Grid.Column="2">
                                    <TextBlock Text="Third field (optional)"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,0,0,2"/>
                                    <ComboBox x:Name="SpecialistFieldPicker" DisplayMemberPath="Name"
                                              SelectionChanged="DependentSelectionChanged"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                        <Border Grid.Row="2"
                                Grid.Column="2"
                                VerticalAlignment="Top"
                                BorderBrush="#A7A7A2"
                                BorderThickness="1"
                                Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="EDUCATION XP"
                                           FontSize="11"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="EducationModuleCost"
                                           FontFamily="{StaticResource MontserratBlack}"
                                           FontSize="21"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <GroupBox Grid.Row="2" Header="Education Overview">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,6">
                            <StackPanel>
                                <TextBlock x:Name="SchoolDescription"
                                           TextWrapping="Wrap"
                                           Foreground="#454545"
                                           LineHeight="20"/>
                                <TextBlock x:Name="EducationFieldsSummary"
                                           TextWrapping="Wrap"
                                           Foreground="#666666"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </Grid>

            <Grid x:Name="Stage4Page" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="430"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="STAGE 4 · CAREERS" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="First career (optional)" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="RealLifePicker" DisplayMemberPath="Name"
                                  SelectionChanged="RealLifeSelectionChanged"/>
                        <TextBlock x:Name="RealLifeDescription" TextWrapping="Wrap"
                                   Foreground="#555555" Margin="0,8,12,12"/>
                        <TextBlock Text="Second career (optional)" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="SecondRealLifePicker" DisplayMemberPath="Name"
                                  SelectionChanged="RealLifeSelectionChanged"/>
                        <TextBlock x:Name="SecondRealLifeDescription" TextWrapping="Wrap"
                                   Foreground="#555555" Margin="0,8,12,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="ReviewPage" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="REVIEW CHARACTER" Style="{StaticResource SectionTitle}" Margin="0"/>
                    <TextBlock Grid.Column="1" Text="Module cost" Foreground="#666"/>
                    <TextBlock Grid.Column="1" x:Name="ModuleCost" Margin="0,22,0,0" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Grid.Column="3" Text="Allocated XP" Foreground="#666"/>
                    <TextBlock Grid.Column="3" x:Name="SpentXp" Margin="0,22,0,0" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Grid.Column="5" Text="Free XP" Foreground="#666"/>
                    <TextBlock Grid.Column="5" x:Name="FreeXp" Margin="0,22,0,0" FontSize="20" FontWeight="Bold"/>
                </Grid>
            </Grid>

            <Border x:Name="ChoicesHost"
                    Width="360"
                    HorizontalAlignment="Right"
                    BorderBrush="#C9C8C3"
                    BorderThickness="1,0,0,0"
                    Padding="24,0,0,0"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="REQUIRED CHOICES"
                                       FontFamily="{StaticResource MontserratBlack}"
                                       FontSize="18"
                                       Foreground="#202020"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1"
                                    BorderBrush="#A7A7A2"
                                    BorderThickness="1"
                                    Padding="8,5">
                                <StackPanel>
                                    <TextBlock Text="FREE XP"
                                               FontSize="11"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="RunningFreeXp"
                                               FontFamily="{StaticResource MontserratBlack}"
                                               FontSize="21"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <StackPanel x:Name="ChoicesPanel"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="TotalsHost"
                    Grid.Row="2"
                    BorderBrush="#C9C8C3"
                    BorderThickness="0,1,0,0"
                    Padding="0,12,0,0"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="CHARACTER TOTALS"
                               FontFamily="{StaticResource MontserratBlack}"
                               FontSize="16"
                               Foreground="#252525"/>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="145"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <DataGrid x:Name="PreviewAttributes"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Attributes" Binding="{Binding Name}" Width="78"/>
                                <DataGridTextColumn Header="XP" Binding="{Binding Value}" Width="55"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <DataGrid Grid.Column="2"
                                  x:Name="PreviewTraits"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Traits" Binding="{Binding Name}" Width="290"/>
                                <DataGridTextColumn Header="XP" Binding="{Binding Value}" Width="55"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <DataGrid Grid.Column="4"
                                  x:Name="PreviewSkills"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Skills" Binding="{Binding Name}" Width="290"/>
                                <DataGridTextColumn Header="XP" Binding="{Binding Value}" Width="55"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1" Grid.Column="1" BorderBrush="#D0CFCA" BorderThickness="0,1,0,0">
            <Grid Margin="32,12">
                <Button Content="Cancel" Click="Cancel_Click"
                        HorizontalAlignment="Left" Style="{StaticResource NavButton}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BackButton" Content="Back" Click="Back_Click"
                            Style="{StaticResource NavButton}"/>
                    <Button x:Name="NextButton" Content="Next" Click="Next_Click"
                            Style="{StaticResource NavButton}" IsDefault="True"/>
                    <Button x:Name="CreateButton" Content="Create Character"
                            Click="Create_Click" Style="{StaticResource NavButton}"
                            Background="#A7332B" Foreground="White"
                            Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
