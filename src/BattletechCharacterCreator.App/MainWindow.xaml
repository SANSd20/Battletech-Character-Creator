<Window x:Class="BattletechCharacterCreator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="A Time of War Character Editor"
        Width="1240" Height="780"
        MinWidth="1050" MinHeight="680"
        Background="#F4F3F0">
    <Window.Resources>
        <FontFamily x:Key="MontserratBlack">/BattletechCharacterCreator.App;component/Assets/Fonts/#Montserrat</FontFamily>
        <Style x:Key="EditorLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
            <Setter Property="Foreground" Value="#30302E"/>
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MontserratBlack}"/>
            <Setter Property="FontSize" Value="23"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#555551"/>
        </Style>
        <Style x:Key="XpButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="XpRow" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsShort}" Value="True">
                    <Setter Property="Background" Value="#FFF0D2"/>
                    <Setter Property="ToolTip" Value="{Binding TargetText}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#292A28">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="A TIME OF WAR"
                               FontFamily="{StaticResource MontserratBlack}"
                               FontSize="18"
                               Foreground="White"/>
                    <TextBlock Text="CHARACTER EDITOR"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="11"
                               Foreground="#C7C7C2"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="New" Click="New_Click"/>
                    <Button Content="Wizard" Click="Wizard_Click"/>
                    <Button Content="Open" Click="Open_Click"/>
                    <Button Content="Save" Click="Save_Click"/>
                    <Button Content="Save As" Click="SaveAs_Click"/>
                    <Button Content="Preview" Click="PreviewSheet_Click"/>
                    <Button Content="Export PDF" Click="ExportPdf_Click"/>
                    <Button Content="Recalculate" Click="Recalculate_Click"/>
                </StackPanel>
                <TextBlock Grid.Column="3"
                           x:Name="FileStatus"
                           Foreground="#D4D4CF"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="330"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="#ECEBE7"
                    BorderBrush="#CECDC8"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,18,18,22">
                        <TextBlock Text="CHARACTER"
                                   FontFamily="{StaticResource MontserratBlack}"
                                   FontSize="20"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="Name" Style="{StaticResource EditorLabel}"/>
                        <TextBox Text="{Binding CharacterName, UpdateSourceTrigger=PropertyChanged}"
                                 LostKeyboardFocus="EditorFieldChanged"/>

                        <TextBlock Text="Affiliation" Style="{StaticResource EditorLabel}"/>
                        <ComboBox ItemsSource="{Binding Catalog.Affiliations}"
                                  Text="{Binding Character.Affiliation, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  SelectionChanged="EditorSelectionChanged"/>
                        <TextBlock Text="Sub-affiliation" Style="{StaticResource EditorLabel}"/>
                        <TextBox Text="{Binding SubAffiliation, UpdateSourceTrigger=PropertyChanged}"
                                 LostKeyboardFocus="EditorFieldChanged"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Clan caste" Style="{StaticResource EditorLabel}"/>
                                <TextBox Text="{Binding Character.ClanCaste, UpdateSourceTrigger=PropertyChanged}"
                                         LostKeyboardFocus="EditorFieldChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Clan training" Style="{StaticResource EditorLabel}"/>
                                <TextBox Text="{Binding Character.ClanTrainingField, UpdateSourceTrigger=PropertyChanged}"
                                         LostKeyboardFocus="EditorFieldChanged"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Home planet" Style="{StaticResource EditorLabel}"/>
                        <ComboBox ItemsSource="{Binding Catalog.Planets}"
                                  Text="{Binding Character.HomePlanet, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  SelectionChanged="EditorSelectionChanged"/>
                        <TextBlock Text="Phenotype" Style="{StaticResource EditorLabel}"/>
                        <ComboBox ItemsSource="{Binding Catalog.Phenotypes}"
                                  Text="{Binding Character.Phenotype, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  SelectionChanged="EditorSelectionChanged"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Sex" Style="{StaticResource EditorLabel}"/>
                                <ComboBox ItemsSource="{Binding SexOptions}"
                                          SelectedItem="{Binding Sex, UpdateSourceTrigger=PropertyChanged}"
                                          SelectionChanged="EditorSelectionChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Age" Style="{StaticResource EditorLabel}"/>
                                <TextBox Text="{Binding Age, UpdateSourceTrigger=PropertyChanged}"
                                         LostKeyboardFocus="EditorFieldChanged"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Height (cm)" Style="{StaticResource EditorLabel}"/>
                                <TextBox Text="{Binding CharacterHeight, UpdateSourceTrigger=PropertyChanged}"
                                         LostKeyboardFocus="EditorFieldChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Weight (kg)" Style="{StaticResource EditorLabel}"/>
                                <TextBox Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}"
                                         LostKeyboardFocus="EditorFieldChanged"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Hair" Style="{StaticResource EditorLabel}"/>
                                <ComboBox ItemsSource="{Binding Catalog.HairColors}"
                                          Text="{Binding Character.HairColor, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          SelectionChanged="EditorSelectionChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Eyes" Style="{StaticResource EditorLabel}"/>
                                <ComboBox ItemsSource="{Binding Catalog.EyeColors}"
                                          Text="{Binding Character.EyeColor, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          SelectionChanged="EditorSelectionChanged"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <TabControl x:Name="EditorTabs" Grid.Column="1" Margin="18,14,18,18"
                        SelectionChanged="EditorTabs_SelectionChanged">
                <TabItem Header="Summary">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="160"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="102"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="102"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="102"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Character.Name}"
                                           FontFamily="{StaticResource MontserratBlack}"
                                           FontSize="24"/>
                                <TextBlock Text="{Binding Character.Affiliation}"
                                           FontSize="14"
                                           Foreground="#666661"/>
                            </StackPanel>
                            <Border Grid.Column="1" BorderBrush="#A7A7A2"
                                    BorderThickness="1" Padding="7,5">
                                <StackPanel>
                                    <TextBlock Text="SPENT XP" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock Text="{Binding Summary.SpentXp}" Style="{StaticResource MetricValue}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" BorderBrush="#A7A7A2"
                                    BorderThickness="1" Padding="7,5">
                                <StackPanel>
                                    <TextBlock Text="FREE XP" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock Text="{Binding Summary.FreeXp}" Style="{StaticResource MetricValue}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="5" BorderBrush="#A7A7A2"
                                    BorderThickness="1" Padding="7,5">
                                <StackPanel>
                                    <TextBlock Text="C-BILLS" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock Text="{Binding Summary.RemainingCBills}" Style="{StaticResource MetricValue}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <GroupBox Header="Life Path">
                                <Grid Margin="8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Clan"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Character.SubAffiliation}"/>
                                    <TextBlock Grid.Row="1" Text="Caste"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Character.ClanCaste}"/>
                                    <TextBlock Grid.Row="2" Text="Training"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding Character.ClanTrainingField}"/>
                                    <TextBlock Grid.Row="3" Text="Childhood"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2">
                                        <Run Text="{Binding Character.EarlyChildhood}"/><Run Text=" / "/>
                                        <Run Text="{Binding Character.LateChildhood}"/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="4" Text="Education"/>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding Character.School}"/>
                                </Grid>
                            </GroupBox>
                            <GroupBox Grid.Column="2" Header="XP Allocation">
                                <Grid Margin="8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Attributes"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Summary.AttributeXp}"/>
                                    <TextBlock Grid.Row="1" Text="Skills"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Summary.SkillXp}"/>
                                    <TextBlock Grid.Row="2" Text="Traits"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Summary.TraitXp}"/>
                                </Grid>
                            </GroupBox>
                            <GroupBox Grid.Column="4" Header="Movement &amp; Load">
                                <Grid Margin="8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Walk / Run / Sprint"/>
                                    <TextBlock Grid.Column="1">
                                        <Run Text="{Binding Summary.Walk}"/><Run Text=" / "/>
                                        <Run Text="{Binding Summary.Run}"/><Run Text=" / "/>
                                        <Run Text="{Binding Summary.Sprint}"/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="1" Text="Climb / Crawl / Swim"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1">
                                        <Run Text="{Binding Summary.Climb}"/><Run Text=" / "/>
                                        <Run Text="{Binding Summary.Crawl}"/><Run Text=" / "/>
                                        <Run Text="{Binding Summary.Swim}"/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="2" Text="Capacity"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Summary.CarryingCapacity}"/>
                                    <TextBlock Grid.Row="3" Text="Inventory mass"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Summary.InventoryMass}"/>
                                </Grid>
                            </GroupBox>
                        </Grid>

                        <GroupBox Grid.Row="4" Header="Rule Check">
                            <Grid Margin="8,4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding RuleStatus}"
                                           Foreground="{Binding RuleStatusBrush}"
                                           FontWeight="SemiBold"/>
                                <DataGrid Grid.Row="2"
                                          ItemsSource="{Binding PrerequisiteIssues}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Type" Binding="{Binding Category}" Width="120"/>
                                        <DataGridTextColumn Header="Requirement" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="Required XP" Binding="{Binding RequiredXp}" Width="110"/>
                                        <DataGridTextColumn Header="Current XP" Binding="{Binding ActualXp}" Width="110"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </TabItem>

                <TabItem Header="Attributes">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="92"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Spend XP in 5-point increments. Highlighted rows have unmet prerequisites."
                                       Foreground="#555551"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" BorderBrush="#A7A7A2"
                                    BorderThickness="1" Padding="6,3">
                                <StackPanel>
                                    <TextBlock Text="FREE XP" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock Text="{Binding Summary.FreeXp}"
                                               FontFamily="{StaticResource MontserratBlack}"
                                               FontSize="17"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <DataGrid x:Name="AttributesGrid" Grid.Row="2"
                                  ItemsSource="{Binding AttributeRows}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  IsReadOnly="True" RowStyle="{StaticResource XpRow}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Attribute" Binding="{Binding Name}"
                                                    Width="*" MinWidth="280"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding Level}"
                                                    Width="90" MinWidth="90"/>
                                <DataGridTextColumn Header="Target" Binding="{Binding TargetText}"
                                                    Width="150" MinWidth="150"/>
                                <DataGridTemplateColumn Header="XP" Width="155" MinWidth="155">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="−" Style="{StaticResource XpButton}"
                                                        ToolTip="Remove 5 XP" Tag="{Binding}"
                                                        Click="DecreaseXp_Click"/>
                                                <TextBlock Text="{Binding Xp}" Width="62"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"/>
                                                <Button Content="+" Style="{StaticResource XpButton}"
                                                        ToolTip="Add 5 XP" Tag="{Binding}"
                                                        Click="IncreaseXp_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="Skills">
                    <DockPanel Margin="8">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="92"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="SkillPicker" ItemsSource="{Binding Catalog.SkillNames}" Width="285"/>
                                <Button Click="AddSkill_Click">Add</Button>
                                <Button Click="RemoveSkill_Click">Remove</Button>
                            </StackPanel>
                            <TextBox Grid.Column="2"
                                     Text="{Binding SkillFilter, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Filter skills"
                                     VerticalContentAlignment="Center"/>
                            <Border Grid.Column="4" BorderBrush="#A7A7A2"
                                    BorderThickness="1" Padding="6,2">
                                <StackPanel>
                                    <TextBlock Text="FREE XP" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock Text="{Binding Summary.FreeXp}"
                                               FontFamily="{StaticResource MontserratBlack}"
                                               FontSize="16"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <DataGrid x:Name="SkillsGrid" ItemsSource="{Binding SkillRowsView}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  IsReadOnly="True" RowStyle="{StaticResource XpRow}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Skill" Binding="{Binding Name}"
                                                    Width="*" MinWidth="280"/>
                                <DataGridTextColumn Header="Level" Binding="{Binding Level}"
                                                    Width="80" MinWidth="80"/>
                                <DataGridTextColumn Header="Target" Binding="{Binding TargetText}"
                                                    Width="150" MinWidth="150"/>
                                <DataGridTemplateColumn Header="XP" Width="155" MinWidth="155">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="−" Style="{StaticResource XpButton}"
                                                        ToolTip="Remove 5 XP" Tag="{Binding}"
                                                        Click="DecreaseXp_Click"/>
                                                <TextBlock Text="{Binding Xp}" Width="62"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"/>
                                                <Button Content="+" Style="{StaticResource XpButton}"
                                                        ToolTip="Add 5 XP" Tag="{Binding}"
                                                        Click="IncreaseXp_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Traits">
                    <DockPanel Margin="8">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="92"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="TraitPicker" ItemsSource="{Binding Catalog.TraitNames}" Width="285"/>
                                <Button Click="AddTrait_Click">Add</Button>
                                <Button Click="RemoveTrait_Click">Remove</Button>
                            </StackPanel>
                            <TextBox Grid.Column="2"
                                     Text="{Binding TraitFilter, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Filter traits"
                                     VerticalContentAlignment="Center"/>
                            <Border Grid.Column="4" BorderBrush="#A7A7A2"
                                    BorderThickness="1" Padding="6,2">
                                <StackPanel>
                                    <TextBlock Text="FREE XP" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock Text="{Binding Summary.FreeXp}"
                                               FontFamily="{StaticResource MontserratBlack}"
                                               FontSize="16"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <DataGrid x:Name="TraitsGrid" ItemsSource="{Binding TraitRowsView}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  IsReadOnly="True" RowStyle="{StaticResource XpRow}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Trait" Binding="{Binding Name}"
                                                    Width="*" MinWidth="280"/>
                                <DataGridTextColumn Header="Level" Binding="{Binding Level}"
                                                    Width="80" MinWidth="80"/>
                                <DataGridTextColumn Header="Target" Binding="{Binding TargetText}"
                                                    Width="150" MinWidth="150"/>
                                <DataGridTemplateColumn Header="XP" Width="155" MinWidth="155">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="−" Style="{StaticResource XpButton}"
                                                        ToolTip="Remove 5 XP" Tag="{Binding}"
                                                        Click="DecreaseXp_Click"/>
                                                <TextBlock Text="{Binding Xp}" Width="62"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"/>
                                                <Button Content="+" Style="{StaticResource XpButton}"
                                                        ToolTip="Add 5 XP" Tag="{Binding}"
                                                        Click="IncreaseXp_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Equipment">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding Catalog.Equipment}"
                                      SelectedItem="{Binding SelectedEquipmentCatalogItem}"
                                      DisplayMemberPath="Name"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      Margin="0,0,8,8"/>
                            <Button Grid.Column="1" Content="Add equipment"
                                    Click="AddEquipment_Click" Margin="0,0,8,8"/>
                            <Button Grid.Column="2" Content="Remove selected"
                                    Click="RemoveEquipment_Click" Margin="0,0,0,8"/>
                        </Grid>
                        <DataGrid Grid.Row="1" x:Name="EquipmentGrid"
                                  ItemsSource="{Binding Equipment}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CellEditEnding="DataGrid_CellEditEnding">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Qty" Binding="{Binding Count}" Width="55"/>
                                <DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="220"/>
                                <DataGridTextColumn Header="Cost" Binding="{Binding Cost}" Width="75"/>
                                <DataGridTextColumn Header="Mass" Binding="{Binding Mass}" Width="70"/>
                                <DataGridTextColumn Header="Locations" Binding="{Binding Locations}" Width="90"/>
                                <DataGridTextColumn Header="Armor" Binding="{Binding Armor}" Width="90"/>
                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal"
                                    HorizontalAlignment="Right" Margin="0,8,4,0">
                            <TextBlock Text="Remaining C-Bills:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Summary.RemainingCBills}" Margin="6,0,20,0"/>
                            <TextBlock Text="Inventory mass:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Summary.InventoryMass}" Margin="6,0,20,0"/>
                            <TextBlock Text="Capacity remaining:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Summary.RemainingCapacity}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Weapons">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding Catalog.Weapons}"
                                      SelectedItem="{Binding SelectedWeaponCatalogItem}"
                                      DisplayMemberPath="Name"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      Margin="0,0,8,8"/>
                            <Button Grid.Column="1" Content="Add weapon"
                                    Click="AddWeapon_Click" Margin="0,0,8,8"/>
                            <Button Grid.Column="2" Content="Remove selected"
                                    Click="RemoveWeapon_Click" Margin="0,0,0,8"/>
                        </Grid>
                        <DataGrid Grid.Row="1" x:Name="WeaponsGrid"
                                  ItemsSource="{Binding Weapons}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CellEditEnding="DataGrid_CellEditEnding"
                                  HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Qty" Binding="{Binding Count}" Width="55"/>
                                <DataGridTextColumn Header="Weapon" Binding="{Binding Name}" Width="180"/>
                                <DataGridTextColumn Header="Skill" Binding="{Binding Skill}" Width="140"/>
                                <DataGridTextColumn Header="Damage" Binding="{Binding Damage}" Width="90"/>
                                <DataGridTextColumn Header="Range" Binding="{Binding Range}" Width="135"/>
                                <DataGridTextColumn Header="Cost" Binding="{Binding Cost}" Width="80"/>
                                <DataGridTextColumn Header="Mass" Binding="{Binding Mass}" Width="70"/>
                                <DataGridTextColumn Header="Shots" Binding="{Binding Shots}" Width="90"/>
                                <DataGridTextColumn Header="Ammo cost" Binding="{Binding AmmoCost}" Width="90"/>
                                <DataGridTextColumn Header="Ammo mass" Binding="{Binding AmmoMass}" Width="90"/>
                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal"
                                    HorizontalAlignment="Right" Margin="0,8,4,0">
                            <TextBlock Text="Remaining C-Bills:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Summary.RemainingCBills}" Margin="6,0,20,0"/>
                            <TextBlock Text="Inventory mass:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Summary.InventoryMass}" Margin="6,0,20,0"/>
                            <TextBlock Text="Capacity remaining:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Summary.RemainingCapacity}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Notes">
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap" Margin="8"/>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
