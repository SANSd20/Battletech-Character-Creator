<Window x:Class="BattletechCharacterCreator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BattleTech Character Creator" Width="1180" Height="760"
        MinWidth="900" MinHeight="600">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <Button Click="New_Click">New</Button>
            <Button Click="Wizard_Click">Create</Button>
            <Button Click="Open_Click">Open</Button>
            <Button Click="Save_Click">Save</Button>
            <Button Click="SaveAs_Click">Save As</Button>
            <Separator/>
            <Button Click="Recalculate_Click">Recalculate</Button>
            <Separator/>
            <TextBlock x:Name="FileStatus" Margin="8,0" VerticalAlignment="Center"/>
        </ToolBar>

        <Grid Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Character" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock Text="Name"/>
                    <TextBox Text="{Binding CharacterName, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Affiliation"/>
                    <ComboBox ItemsSource="{Binding Catalog.Affiliations}"
                              Text="{Binding Character.Affiliation, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"/>
                    <TextBlock Text="Sub-affiliation"/>
                    <TextBox Text="{Binding SubAffiliation, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Home planet"/>
                    <ComboBox ItemsSource="{Binding Catalog.Planets}"
                              Text="{Binding Character.HomePlanet, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"/>
                    <TextBlock Text="Phenotype"/>
                    <ComboBox ItemsSource="{Binding Catalog.Phenotypes}"
                              Text="{Binding Character.Phenotype, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"/>
                    <TextBlock Text="Sex"/>
                    <ComboBox ItemsSource="{Binding SexOptions}"
                              SelectedItem="{Binding Sex, UpdateSourceTrigger=PropertyChanged}"/>
                    <UniformGrid Columns="2">
                        <StackPanel>
                            <TextBlock Text="Age"/>
                            <TextBox Text="{Binding Age, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Height (cm)"/>
                            <TextBox Text="{Binding CharacterHeight, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </UniformGrid>
                    <TextBlock Text="Weight (kg)"/>
                    <TextBox Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Hair"/>
                    <ComboBox ItemsSource="{Binding Catalog.HairColors}"
                              Text="{Binding Character.HairColor, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"/>
                    <TextBlock Text="Eyes"/>
                    <ComboBox ItemsSource="{Binding Catalog.EyeColors}"
                              Text="{Binding Character.EyeColor, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"/>
                </StackPanel>
            </ScrollViewer>

            <TabControl Grid.Column="2">
                <TabItem Header="Summary">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.ColumnSpan="2" Text="Character points" FontSize="18"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Text="Attributes"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Summary.AttributeXp}"/>
                            <TextBlock Grid.Row="2" Text="Skills"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Summary.SkillXp}"/>
                            <TextBlock Grid.Row="3" Text="Traits"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Summary.TraitXp}"/>
                            <TextBlock Grid.Row="4" Text="Spent"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Summary.SpentXp}"/>
                            <TextBlock Grid.Row="5" Text="Free"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Summary.FreeXp}"
                                       FontWeight="Bold"/>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.ColumnSpan="2" Text="Derived values" FontSize="18"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Text="C-Bills"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Summary.RemainingCBills}"/>
                            <TextBlock Grid.Row="2" Text="Capacity"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Summary.CarryingCapacity}"/>
                            <TextBlock Grid.Row="3" Text="Inventory mass"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Summary.InventoryMass}"/>
                            <TextBlock Grid.Row="4" Text="Walk / Run / Sprint"/>
                            <TextBlock Grid.Row="4" Grid.Column="1">
                                <Run Text="{Binding Summary.Walk}"/><Run Text=" / "/>
                                <Run Text="{Binding Summary.Run}"/><Run Text=" / "/>
                                <Run Text="{Binding Summary.Sprint}"/>
                            </TextBlock>
                            <TextBlock Grid.Row="5" Text="Climb / Crawl / Swim"/>
                            <TextBlock Grid.Row="5" Grid.Column="1">
                                <Run Text="{Binding Summary.Climb}"/><Run Text=" / "/>
                                <Run Text="{Binding Summary.Crawl}"/><Run Text=" / "/>
                                <Run Text="{Binding Summary.Swim}"/>
                            </TextBlock>
                            <TextBlock Grid.Row="6" Text="Wealth level"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Summary.WealthLevel}"/>
                        </Grid>

                        <DockPanel Grid.Row="2" Grid.ColumnSpan="3">
                            <TextBlock DockPanel.Dock="Top" Text="Unmet prerequisites" FontSize="18"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <DataGrid ItemsSource="{Binding PrerequisiteIssues}" AutoGenerateColumns="False"
                                      CanUserAddRows="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Category}" Width="120"/>
                                    <DataGridTextColumn Header="Requirement" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Required XP" Binding="{Binding RequiredXp}" Width="120"/>
                                    <DataGridTextColumn Header="Current XP" Binding="{Binding ActualXp}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Attributes">
                    <DataGrid ItemsSource="{Binding Attributes}" AutoGenerateColumns="False"
                              CanUserAddRows="False" Margin="8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Attribute" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="XP" Binding="{Binding Value}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Skills">
                    <DockPanel Margin="8">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                            <ComboBox x:Name="SkillPicker" ItemsSource="{Binding Catalog.SkillNames}" Width="300"/>
                            <Button Click="AddSkill_Click">Add</Button>
                            <Button Click="RemoveSkill_Click">Remove</Button>
                        </StackPanel>
                        <DataGrid x:Name="SkillsGrid" ItemsSource="{Binding Skills}" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Skill" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="XP" Binding="{Binding Value}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Traits">
                    <DockPanel Margin="8">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                            <ComboBox x:Name="TraitPicker" ItemsSource="{Binding Catalog.TraitNames}" Width="300"/>
                            <Button Click="AddTrait_Click">Add</Button>
                            <Button Click="RemoveTrait_Click">Remove</Button>
                        </StackPanel>
                        <DataGrid x:Name="TraitsGrid" ItemsSource="{Binding Traits}" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Trait" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="XP" Binding="{Binding Value}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Equipment">
                    <DataGrid ItemsSource="{Binding Equipment}" AutoGenerateColumns="True" Margin="8"/>
                </TabItem>
                <TabItem Header="Weapons">
                    <DataGrid ItemsSource="{Binding Weapons}" AutoGenerateColumns="True" Margin="8"/>
                </TabItem>
                <TabItem Header="Notes">
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Margin="8"/>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
