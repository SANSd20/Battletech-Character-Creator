<Window x:Class="BattletechCharacterCreator.App.StartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BattleTech Character Creator"
        Width="560" Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="BattleTech Character Creator"
                       FontSize="26"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Where would you like to begin?"
                       FontSize="15"
                       Foreground="#555555"
                       Margin="0,8,0,0"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Click="Wizard_Click"
                    FontSize="18"
                    FontWeight="SemiBold">
                <StackPanel>
                    <TextBlock Text="Character Wizard"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Guided creation"
                               FontSize="13"
                               FontWeight="Normal"
                               Foreground="#555555"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    Click="Editor_Click"
                    FontSize="18"
                    FontWeight="SemiBold">
                <StackPanel>
                    <TextBlock Text="Character Editor"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Open a blank character"
                               FontSize="13"
                               FontWeight="Normal"
                               Foreground="#555555"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
