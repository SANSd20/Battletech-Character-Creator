<Window x:Class="BattletechCharacterCreator.App.StartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="A Time of War Character Creator"
        Width="900" Height="540"
        MinWidth="760" MinHeight="470"
        Background="#ECEBE8"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <FontFamily x:Key="MontserratBlack">/BattletechCharacterCreator.App;component/Assets/Fonts/#Montserrat</FontFamily>

        <Style x:Key="ChoiceButton" TargetType="Button">
            <Setter Property="Height" Value="112"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="22,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Frame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="3"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Frame" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Frame" Property="Opacity" Value="0.78"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Frame" Property="BorderBrush" Value="#7E8B54"/>
                                <Setter TargetName="Frame" Property="BorderThickness" Value="5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="34,28,34,30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="34"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#F8F8F6"
                BorderBrush="#202020"
                BorderThickness="3"
                CornerRadius="5">
            <Grid ClipToBounds="True">
                <Rectangle Fill="#D8D9D3" Height="54" VerticalAlignment="Bottom"/>
                <Image Source="Assets/Images/pilot6.jpg"
                       Margin="20,18,20,0"
                       Stretch="Uniform"
                       VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="A TIME OF WAR"
                       FontFamily="{StaticResource MontserratBlack}"
                       FontSize="48"
                       Foreground="#171717"
                       TextWrapping="NoWrap"/>
            <Border Grid.Row="1" Background="#A7332B" Margin="0,7,0,0"/>
            <StackPanel Grid.Row="2" Margin="0,14,0,0">
                <TextBlock Text="CHARACTER CREATOR"
                           FontFamily="Bahnschrift SemiBold"
                           FontSize="22"
                           Foreground="#303030"/>
                <TextBlock Text="Where would you like to begin?"
                           FontSize="16"
                           Foreground="#5A5A57"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="4">
                <Button Click="Wizard_Click"
                        Style="{StaticResource ChoiceButton}"
                        Background="#A7332B"
                        BorderBrush="#6F211C"
                        Foreground="White"
                        IsDefault="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="1"
                                   FontFamily="{StaticResource MontserratBlack}"
                                   FontSize="34"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Character Wizard"
                                       FontSize="23"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Guided character creation"
                                       FontSize="14"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="›"
                                   FontSize="38"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Button Click="Editor_Click"
                        Style="{StaticResource ChoiceButton}"
                        Background="#30312F"
                        BorderBrush="#181918"
                        Foreground="White">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="2"
                                   FontFamily="{StaticResource MontserratBlack}"
                                   FontSize="34"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Character Editor"
                                       FontSize="23"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Open or edit a character"
                                       FontSize="14"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="›"
                                   FontSize="38"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
